# Google OAuth credentials for BookShelf
# Project ID: bookshelf-499102
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google API Key for Picker API (must be NEXT_PUBLIC_ to be available in the browser)
# Get this from Google Cloud Console → APIs & Services → Credentials → API Keys
# Ensure the key is authorized for Drive API and Picker API
NEXT_PUBLIC_GOOGLE_API_KEY=

# NextAuth configuration
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
