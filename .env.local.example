# Google OAuth credentials for BookShelf
# Project ID: bookshelf-499102
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Google API Key for Picker API (must be NEXT_PUBLIC_ to be available in the browser)
# Get this from Google Cloud Console → APIs & Services → Credentials → API Keys
# Ensure the key is authorized for Drive API and Picker API
NEXT_PUBLIC_GOOGLE_API_KEY=your_api_key_here

# NextAuth configuration
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Vercel KV / Upstash — cross-device userdata sync (metadata, links, collections, YouTube edits)
# Auto-populated when you attach Vercel KV to the project; copy from the Vercel dashboard for local dev.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Local book sync script variables
# Set these in PowerShell or your environment before running `npm run sync-local-books`
LOCAL_BOOKS_ROOT=C:\dev\Books
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
